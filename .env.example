# API Keys & Secrets
# Copy this file to .env.local and fill in your actual values

# ============================================
# ANTHROPIC (Claude API) - REQUIRED
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxx...

# ============================================
# VOYAGE AI (Embeddings) - REQUIRED
# ============================================
VOYAGE_API_KEY=voyage-xxx...

# ============================================
# DATABASE - REQUIRED
# ============================================
DATABASE_URL=postgresql://aimarketer:secure_password_change_me@localhost:5432/ai_marketing
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis for caching and task queues
REDIS_URL=redis://localhost:6379
EMBED_CACHE_TTL_SECONDS=86400
AGENT_RESPONSE_CACHE_TTL_SECONDS=86400

# ============================================
# TOKEN MONITORING & LIMITS
# ============================================
# Set a limit to 0 to disable enforcement for that provider.
CLAUDE_TOKEN_LIMIT=500000
VOYAGE_TOKEN_LIMIT=250000
AGENT_TELEMETRY_TTL_SECONDS=2592000
AGENT_TELEMETRY_MAX_EVENTS=10000

# Task-specific Claude output budgets. Keep narrow tasks small; tune only per task type.
# Score threshold below which Scenario A uses Haiku instead of Sonnet (default 50, range 0-100)
HAIKU_SCORE_THRESHOLD=50
MAX_TOKENS_SCORING=512
MAX_TOKENS_EVALUATOR_JSON=1024
MAX_TOKENS_MARKETER_BRIEF=2400
MAX_TOKENS_CONTENT_GENERATION=4096
MAX_TOKENS_REVISION_DELTA=1500
MAX_EVALUATOR_CONTENT_CHARS=1800
MIN_REVISION_FEEDBACK_CHARS=40

# RAG context budget for prompts.
RAG_MAX_CHARS_PER_CHUNK=1200
RAG_MAX_TOTAL_CHARS=4000
RAG_MIN_SIMILARITY=0.72

# Rolling window for token limits. When > 0, counters auto-reset after this many seconds
# (e.g. 86400 = daily limit, 2592000 = monthly limit). Default 0 = lifetime counter.
TOKEN_LIMIT_WINDOW_SECONDS=0

# Cost estimate rates, USD per 1M tokens. Keep current values in deployment config.
CLAUDE_INPUT_COST_PER_MTOKENS=0
CLAUDE_OUTPUT_COST_PER_MTOKENS=0

# ============================================
# N8N (Workflow Orchestration) - OPTIONAL
# ============================================
N8N_HOST=http://localhost:5678
N8N_API_KEY=xxx...
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ============================================
# FILE STORAGE (S3 / MinIO)
# ============================================
# For AWS S3
S3_ACCESS_KEY_ID=xxx
S3_SECRET_ACCESS_KEY=xxx
S3_BUCKET_NAME=ai-marketing-platform
S3_REGION=us-east-1

# Or for MinIO (self-hosted)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ai-marketing

# ============================================
# SPEECH-TO-TEXT (Cohere)
# ============================================
COHERE_API_KEY=xxx...

# ============================================
# JWT & AUTH
# ============================================
# For RS256 (Production), provide keys. For HS256 (Dev), use JWT_SECRET.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_SECRET=your-super-secret-key-change-this-in-production
# Access token TTL (default 15m). Refresh token TTL is hardcoded to 7d.
# Shared bearer token required by n8n for all /api/internal/* calls.
INTERNAL_API_TOKEN=change-me-shared-with-n8n
# INTERNAL_SERVICE_USER_ID: UUID used as app.user_id in RLS context for n8n callbacks.
# Set to any valid UUID. Does not need to exist in users table.
INTERNAL_SERVICE_USER_ID=00000000-0000-0000-0000-000000000001

# ============================================
# APPLICATION
# ============================================
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=DEBUG

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=3001
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# WORKER & QUEUE
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
WORKER_CONCURRENCY=4

# ============================================
# MONITORING & LOGGING
# ============================================
SENTRY_DSN=https://xxx@sentry.io/xxx
OPENTELEMETRY_ENABLED=false
